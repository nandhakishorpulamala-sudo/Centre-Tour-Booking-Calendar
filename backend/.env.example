# Postgres connection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=centredb
POSTGRES_HOST=db
POSTGRES_PORT=5432

PORT=4000

# Notifications (placeholders)
EMAIL_PROVIDER=stub
EMAIL_FROM=no-reply@example.com
WHATSAPP_PROVIDER=stub
WHATSAPP_API_KEY=
OPENAI_API_KEY=

# SMTP (nodemailer) settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# WhatsApp (choose provider: 'meta' or 'twilio')
# Meta WhatsApp Cloud API (Facebook)
WHATSAPP_PROVIDER=meta
WA_META_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WA_META_TOKEN=YOUR_WHATSAPP_CLOUD_TOKEN

# Twilio WhatsApp (alternative)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+1415...
